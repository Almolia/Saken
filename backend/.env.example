DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*,127.0.0.1,localhost

# Optional: extra frontend origins beyond localhost and auto-detected GitHub Codespaces URL
FRONTEND_EXTRA_ORIGINS=

# Optional manual overrides. Usually you can leave both empty because the backend
# now auto-adds localhost and the active GitHub Codespaces frontend URL.
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ACCESS_COOKIE_NAME=saken_access_token
JWT_REFRESH_COOKIE_NAME=saken_refresh_token
JWT_COOKIE_SECURE=False
JWT_COOKIE_SAMESITE=Lax

# Optional: set when frontend is hosted on another public domain and you need
# cookies to be scoped for that host/domain.
FRONTEND_APP_URL=
AUTH_COOKIE_DOMAIN=
CSRF_COOKIE_DOMAIN=
SESSION_COOKIE_DOMAIN=
